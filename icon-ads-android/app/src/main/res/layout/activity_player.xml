<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Player de video (ExoPlayer) -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:show_buffering="when_playing"
        app:resize_mode="fit" />

    <!-- Visor de imágenes -->
    <ImageView
        android:id="@+id/image_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:background="@android:color/black"
        android:visibility="gone" />

    <!-- Admin message overlay (#4) -->
    <FrameLayout
        android:id="@+id/message_overlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#CC000000"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/message_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:text="" />

    </FrameLayout>

    <!-- Survey overlay (#47) -->
    <FrameLayout
        android:id="@+id/survey_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="420dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:background="#1C2B3A"
            android:padding="28dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Encuesta rápida"
                android:textColor="#9CA3AF"
                android:textSize="13sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/survey_question_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.3"
                android:layout_marginBottom="20dp" />

            <Button
                android:id="@+id/survey_opt_0"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="8dp"
                android:backgroundTint="#1D4ED8"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/survey_opt_1"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="8dp"
                android:backgroundTint="#1D4ED8"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/survey_opt_2"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="8dp"
                android:backgroundTint="#1D4ED8"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/survey_opt_3"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="8dp"
                android:backgroundTint="#1D4ED8"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/survey_dismiss"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Responder después"
                android:textColor="#6B7280"
                android:textSize="14sp"
                android:gravity="center"
                android:padding="12dp"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </FrameLayout>

    <!-- Splash / Loading overlay — full screen, visible from launch -->
    <FrameLayout
        android:id="@+id/loading_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ICON ADS"
                android:textColor="#FFFFFF"
                android:textSize="52sp"
                android:textStyle="bold"
                android:letterSpacing="0.15" />

            <View
                android:layout_width="100dp"
                android:layout_height="2dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp"
                android:background="#FFFFFF"
                android:alpha="0.35" />

            <ProgressBar
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:indeterminateTint="@android:color/white" />

            <TextView
                android:id="@+id/loading_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Iniciando..."
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:alpha="0.6" />

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
