generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           Int        @id @default(autoincrement())
  email        String     @unique
  password     String
  name         String
  role         String     @default("admin")
  failedLogins Int        @default(0) @map("failed_logins")
  lockedUntil  DateTime?  @map("locked_until")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  auditLogs    AuditLog[]

  @@map("users")
}

model Client {
  id        Int        @id @default(autoincrement())
  name      String
  email     String     @unique
  phone     String?
  company   String?
  rut       String?
  address   String?
  color          String?
  contactName    String?   @map("contact_name")
  contactPhone   String?   @map("contact_phone")
  active         Boolean   @default(true)
  deletedAt      DateTime? @map("deleted_at")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  campaigns Campaign[]

  @@map("clients")
}

model Campaign {
  id        Int       @id @default(autoincrement())
  clientId  Int       @map("client_id")
  client    Client    @relation(fields: [clientId], references: [id])
  name      String
  startDate DateTime  @map("start_date")
  endDate   DateTime  @map("end_date")
  active    Boolean   @default(true)
  cpm                Float?
  maxImpressions     Int?      @map("max_impressions")
  budget             Float?
  observations       String?
  targetImpressions  Int?      @map("target_impressions")
  deletedAt          DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  ads       Ad[]
  metrics   Metric[]
  comments  Comment[]

  @@map("campaigns")
}

enum AdType {
  video
  image
}

model Ad {
  id             Int          @id @default(autoincrement())
  campaignId     Int          @map("campaign_id")
  campaign       Campaign     @relation(fields: [campaignId], references: [id])
  name           String
  type           AdType
  fileUrl        String       @map("file_url")
  filename       String
  durationS      Int          @map("duration_s")
  active         Boolean      @default(true)
  approvalStatus String       @default("approved") @map("approval_status")
  priority       Int          @default(0)
  targetUrl      String?      @map("target_url")
  startsAt       DateTime?    @map("starts_at")
  endsAt         DateTime?    @map("ends_at")
  tags           String[]     @default([])
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  playlistAds    PlaylistAd[]
  metrics        Metric[]

  @@map("ads")
}

model Playlist {
  id          Int               @id @default(autoincrement())
  name        String
  version     Int               @default(1)
  contentHash String?           @map("content_hash")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  playlistAds  PlaylistAd[]
  tablets      Tablet[]
  tabletGroups TabletGroup[]
  versions     PlaylistVersion[]

  @@map("playlists")
}

model PlaylistVersion {
  id         Int      @id @default(autoincrement())
  playlistId Int      @map("playlist_id")
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  version    Int
  snapshot   Json
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("playlist_versions")
}

model PlaylistAd {
  id         Int      @id @default(autoincrement())
  playlistId Int      @map("playlist_id")
  playlist   Playlist @relation(fields: [playlistId], references: [id])
  adId       Int      @map("ad_id")
  ad         Ad       @relation(fields: [adId], references: [id])
  order      Int
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("playlist_ads")
}

enum TabletStatus {
  online
  offline
  syncing
}

model TabletGroup {
  id         Int       @id @default(autoincrement())
  name       String
  playlistId Int?      @map("playlist_id")
  playlist   Playlist? @relation(fields: [playlistId], references: [id], onDelete: SetNull)
  tablets    Tablet[]
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("tablet_groups")
}

model Tablet {
  id         Int          @id @default(autoincrement())
  deviceId   String       @unique @map("device_id")
  token      String       @unique
  name       String
  zone       String?
  timezone   String?      @default("America/Montevideo")
  playlistId Int?         @map("playlist_id")
  playlist   Playlist?    @relation(fields: [playlistId], references: [id])
  groupId           Int?         @map("group_id")
  group             TabletGroup? @relation(fields: [groupId], references: [id])
  scheduleAt        DateTime?    @map("schedule_at")
  lastSync          DateTime?    @map("last_sync")
  status            TabletStatus @default(offline)
  notes             String?
  maintenanceUntil  DateTime?    @map("maintenance_until")
  driverName        String?      @map("driver_name")
  licensePlate      String?      @map("license_plate")
  spotPrice         Float?       @map("spot_price")
  batteryLevel      Int?         @map("battery_level")
  temperatureC      Float?       @map("temperature_c")
  appVersion        String?      @map("app_version")
  lastIp            String?      @map("last_ip")
  osVersion         String?      @map("os_version")
  deviceModel       String?      @map("device_model")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  metrics    Metric[]
  errorLogs  ErrorLog[]
  syncLogs   SyncLog[]
  messages   TabletMessage[]

  @@map("tablets")
}

model SyncLog {
  id        Int      @id @default(autoincrement())
  tabletId  Int      @map("tablet_id")
  tablet    Tablet   @relation(fields: [tabletId], references: [id], onDelete: Cascade)
  version   Int      @default(0)
  success   Boolean  @default(true)
  errorMsg  String?  @map("error_msg")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tabletId])
  @@map("sync_logs")
}

model TabletMessage {
  id        Int      @id @default(autoincrement())
  tabletId  Int      @map("tablet_id")
  tablet    Tablet   @relation(fields: [tabletId], references: [id], onDelete: Cascade)
  message   String
  shown     Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("tablet_messages")
}

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}

model Metric {
  id              Int      @id @default(autoincrement())
  tabletId        Int      @map("tablet_id")
  tablet          Tablet   @relation(fields: [tabletId], references: [id])
  adId            Int      @map("ad_id")
  ad              Ad       @relation(fields: [adId], references: [id])
  campaignId      Int      @map("campaign_id")
  campaign        Campaign @relation(fields: [campaignId], references: [id])
  playedAt        DateTime @map("played_at")
  durationPlayedS Int      @map("duration_played_s")
  completed       Boolean
  error           Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([tabletId])
  @@index([campaignId])
  @@index([playedAt])
  @@map("metrics")
}

model ErrorLog {
  id         Int      @id @default(autoincrement())
  tabletId   Int      @map("tablet_id")
  tablet     Tablet   @relation(fields: [tabletId], references: [id])
  errorType  String   @map("error_type")
  message    String
  occurredAt DateTime @map("occurred_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("error_logs")
}

model Comment {
  id         Int      @id @default(autoincrement())
  campaignId Int      @map("campaign_id")
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId     Int?     @map("user_id")
  authorName String   @map("author_name")
  body       String
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("comments")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  Int?     @map("entity_id")
  details   String?
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model AdminNote {
  id         Int      @id @default(autoincrement())
  body       String
  authorName String   @default("Admin") @map("author_name")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("admin_notes")
}
