DATABASE_URL="postgresql://user:password@localhost:5432/icon_ads"
JWT_SECRET="change-me-in-production-min-32-chars"
JWT_EXPIRES_IN="7d"
NODE_ENV="development"
PORT=3000
FRONTEND_URL="http://localhost:3001"

# Optional — shared secret required in the X-Enrollment-Key header on
# POST /api/device/register. Must match icon-ads-android/enrollment.properties
# (key=...) used to build the APK. Skipped entirely if unset. See TECHNICAL.md.
ENROLLMENT_SECRET=""

# Optional — Firebase service account JSON (single line), used to push instant
# force-sync notifications to tablets via FCM instead of waiting for their
# hourly WorkManager poll. Generate at Firebase Console > Project Settings >
# Service accounts > Generate new private key. Skipped entirely if unset —
# force-sync falls back to the "next connection" flag only.
FIREBASE_SERVICE_ACCOUNT=''
