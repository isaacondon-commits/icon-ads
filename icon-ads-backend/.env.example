DATABASE_URL="postgresql://user:password@localhost:5432/icon_ads"
JWT_SECRET="change-me-in-production-min-32-chars"
JWT_EXPIRES_IN="7d"
NODE_ENV="development"
PORT=3000
FRONTEND_URL="http://localhost:3001"

# Optional — shared secret required in the X-Enrollment-Key header on
# POST /api/device/register. Must match icon-ads-android/enrollment.properties
# (key=...) used to build the APK. Skipped entirely if unset. See TECHNICAL.md.
ENROLLMENT_SECRET=""
